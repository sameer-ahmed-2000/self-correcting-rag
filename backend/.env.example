# Self-Correcting RAG — Backend Environment Variables
# Copy this file to .env and fill in the values. Never commit .env to git.

# ── Required ────────────────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Model Configuration ──────────────────────────────────────
# Recommended: llama-3.1-8b-instant (fast, good free tier quota)
# Alternative: llama-3.3-70b-versatile (more capable, lower daily limit)
GROQ_MODEL=llama-3.1-8b-instant
MAX_TOKENS=512

# ── CORS (comma-separated allowed origins) ───────────────────
# For local dev: http://localhost:5173
# For Docker: http://localhost (nginx on port 80)
# For production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost
