# Self-Correcting RAG — Backend Environment Variables
# Copy this file to .env and fill in the values. Never commit .env to git.

# ── Required ────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here      # https://console.groq.com

# ── Model Configuration ──────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant          # fast model, high free-tier quota
FALLBACK_MODEL=llama-3.1-8b-instant      # used if primary hits rate limit
MAX_TOKENS=512

# ── Security ─────────────────────────────────────────────────
# Set this to enable API key authentication via X-API-Key header.
# Leave blank to disable auth (useful for local dev).
API_KEY=

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ── Redis Cache (optional) ───────────────────────────────────
# If not set, caching is silently disabled and the app still works.
# For Docker Compose: redis://redis:6379
# For local Redis:    redis://localhost:6379
REDIS_URL=
CACHE_TTL_SECONDS=3600
